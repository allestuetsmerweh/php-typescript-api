{
  "name": "php-typescript-api",
  "version": "3.0.0",
  "description": "Build a typed Web API using PHP and TypeScript",
  "main": "client/lib/index.js",
  "types": "client/lib/index.d.ts",
  "directories": {
    "lib": "client/lib",
    "test": "client/tests"
  },
  "scripts": {
    "build": "tsc",
    "eslint": "eslint ./ --fix",
    "jest": "jest",
    "jest-ci": "jest --runInBand",
    "lint": "npm run eslint",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "test": "npm run jest",
    "test-ci": "npm run jest-ci",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allestuetsmerweh/php-typescript-api.git"
  },
  "keywords": [
    "PHP",
    "TypeScript",
    "API"
  ],
  "author": "Simon Hatt",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/allestuetsmerweh/php-typescript-api/issues"
  },
  "homepage": "https://github.com/allestuetsmerweh/php-typescript-api#readme",
  "devDependencies": {
    "@eslint/js": "^10",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@types/jest": "^30.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0",
    "jest": "^30.0",
    "jest-environment-jsdom": "^30.0",
    "knip": "^6.0.1",
    "ts-jest": "^29.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.40.0"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.13",
    "unfetch": "^4.0"
  }
}
